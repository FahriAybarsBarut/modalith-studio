{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
  "configurePresets": [
    {
      "name": "windows-msvc",
      "displayName": "Windows MSVC x64",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/windows-msvc",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "MODALITH_BUILD_TESTS": "ON",
        "MODALITH_BUILD_EXAMPLES": "ON",
        "MODALITH_BUILD_GUI": "ON"
      }
    },
    {
      "name": "ninja-release",
      "displayName": "Ninja Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ninja-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "MODALITH_BUILD_TESTS": "ON",
        "MODALITH_BUILD_EXAMPLES": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "windows-msvc", "configurePreset": "windows-msvc", "configuration": "Release" },
    { "name": "ninja-release", "configurePreset": "ninja-release" }
  ],
  "testPresets": [
    {
      "name": "windows-msvc",
      "configurePreset": "windows-msvc",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ninja-release",
      "configurePreset": "ninja-release",
      "output": { "outputOnFailure": true }
    }
  ]
}
